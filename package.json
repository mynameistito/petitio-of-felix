{
  "name": "petition-of-felix",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply petition-of-felix-pulse --local",
    "db:migrate:remote": "wrangler d1 migrations apply petition-of-felix-pulse --remote",
    "dev": "wrangler dev --test-scheduled",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
